{
  "env": {},
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "~/projects/setup/linked/claude/hooks/pre-commit-format.sh",
            "type": "command"
          },
          {
            "command": "~/projects/setup/linked/claude/hooks/validate-command.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "~/projects/setup/linked/claude/hooks/validate-write.sh",
            "type": "command"
          }
        ],
        "matcher": "Write"
      }
    ]
  },
